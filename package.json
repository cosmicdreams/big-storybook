{
  "name": "big-storybook",
  "version": "3.0.0",
  "description": "Production-ready Storybook for HTML components with WebRTC screen sharing",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "vitest",
    "test:storybook": "vitest --project storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint stories/**/*.js .storybook/**/*.js",
    "lint:fix": "eslint stories/**/*.js .storybook/**/*.js --fix",
    "format": "prettier --write stories/**/*.js .storybook/**/*.js css/**/*.css",
    "format:check": "prettier --check stories/**/*.js .storybook/**/*.js css/**/*.css"
  },
  "keywords": [
    "storybook",
    "webrtc",
    "screen-sharing",
    "components",
    "html"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.7",
    "@storybook/addon-docs": "^10.2.7",
    "@storybook/addon-vitest": "^10.2.7",
    "@storybook/html": "^10.2.7",
    "@storybook/html-vite": "^10.2.7",
    "@storybook/test": "8.6.15",
    "@storybook/test-runner": "^0.24.2",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "^8.57.0",
    "eslint-plugin-storybook": "10.2.7",
    "playwright": "^1.58.1",
    "prettier": "^3.2.0",
    "storybook": "^10.2.7",
    "vite": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "local-iframe": "^1.2.0"
  }
}
