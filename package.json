{
  "name": "big-storybook",
  "version": "3.0.0",
  "author": "",
  "main": "index.js",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@github-ui/storybook-addon-performance-panel": "^1.1.4",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-vitest": "^10.2.16",
    "@storybook/html-vite": "^10.2.16",
    "@storybook/test-runner": "^0.24.2",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "^10.0.3",
    "eslint-plugin-storybook": "10.2.16",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "storybook": "^10.2.16",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "description": "Production-ready Storybook for HTML components with WebRTC screen sharing",
  "keywords": [
    "storybook",
    "webrtc",
    "screen-sharing",
    "components",
    "html"
  ],
  "license": "ISC",
  "scripts": {
    "test": "vitest",
    "test:storybook": "vitest --project storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint stories/**/*.js .storybook/**/*.js",
    "lint:fix": "eslint stories/**/*.js .storybook/**/*.js --fix",
    "format": "prettier --write stories/**/*.js .storybook/**/*.js css/**/*.css",
    "format:check": "prettier --check stories/**/*.js .storybook/**/*.js css/**/*.css"
  },
  "type": "module",
  "overrides": {
    "rollup": "^4.59.0",
    "axios": "^1.13.6",
    "minimatch": "^3.1.3"
  }
}